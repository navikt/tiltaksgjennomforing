        "jsdom": "^26.0.0",
        "less": "^4.2.2",
        "lint-staged": "^15.5.0",
        "prettier": "^3.5.3",
        "storybook": "8.6.18",
        "svgo": "^3.3.2",
        "typescript": "^5.8.2",
        "vite": "^6.2.4",
        "vite-plugin-svgr": "^4.3.0",
        "vitest": "^3.1.1"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,less,css,md}": "pnpm run prettier:fix",
