        "@storybook/blocks": "8.6.18",
        "@storybook/react": "8.6.18",
        "@storybook/react-vite": "8.6.18",
        "@storybook/test": "8.6.18",
        "@testing-library/react": "^16.2.0",
        "@types/lodash.debounce": "^4.0.9",
        "@types/lodash.isequal": "^4.5.8",
        "@types/node": "^22.13.16",
