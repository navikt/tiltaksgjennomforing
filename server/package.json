{
    "name": "tiltaksgjennomforing",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.30.3",
    "homepage": "/tiltaksgjennomforing",
    "engines": {
        "node": ">=24",
        "npm": "please-use-pnpm",
        "yarn": "please-use-pnpm",
        "pnpm": ">= 10.0.0"
    },
    "scripts": {
        "build": "esbuild src/server.ts --bundle --platform=node --outfile=../dist/server/index.cjs --packages=external",
        "dist": "cp -r node_modules ../dist/server",
        "server": "node --openssl-legacy-provider ../dist/server/index.cjs",
        "start": "echo 'Use pnpm run start:labs, pnpm run start:ekstern or pnpm run start:intern'",
        "start:labs": "cross-env LABS=true pnpm run server",
        "start:ekstern": "cross-env ENABLE_EXTERNAL_MENU=true pnpm run server",
        "start:intern": "cross-env ENABLE_INTERNAL_MENU=true INTERN_INGRESS=true pnpm run server"
    },
    "dependencies": {
        "@navikt/arbeidsgiver-notifikasjon-widget": "^7.2.3",
        "@navikt/nav-dekoratoren-moduler": "^3.2.2",
        "@navikt/oasis": "3.7",
        "axios": "^1.8.4",
        "compression": "^1.8.0",
        "cookie-parser": "1.4.7",
        "express": "^5.1.0",
        "helmet": "^8.1.0",
        "http-proxy-middleware": "3.0.3",
        "jsdom": "^26.0.0"
    },
    "devDependencies": {
        "@types/compression": "^1.7.5",
        "@types/cookie-parser": "^1.4.8",
        "@types/express": "^5.0.1",
        "@types/jsdom": "^21.1.7",
        "cross-env": "^7.0.3",
        "esbuild": "^0.25.2",
        "typescript": "^5.8.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
